# TeleHarvest 环境变量示例
# 使用方式：复制此文件为 .env 并填入实际值
#   cp config/.env.example .env
#
# 注意：.env 文件包含敏感信息，已被 .gitignore 忽略，不会提交到仓库。

# ===== Telegram API 凭据（必填）=====
# 申请地址：https://my.telegram.org
TELEHARVEST_API_ID=0
TELEHARVEST_API_HASH=
# Bot Token（可选，使用用户账号登录时留空）
# 通过 @BotFather 创建 Bot 获取
TELEHARVEST_BOT_TOKEN=

# ===== 代理配置（可选，通过环境变量覆盖 config.yaml）=====
# TELEHARVEST_PROXY__ENABLED=true
# TELEHARVEST_PROXY__TYPE=socks5
# TELEHARVEST_PROXY__HOST=127.0.0.1
# TELEHARVEST_PROXY__PORT=1080
# TELEHARVEST_PROXY__USERNAME=
# TELEHARVEST_PROXY__PASSWORD=

# ===== 日志级别覆盖（可选）=====
# TELEHARVEST_LOGGING__LEVEL=DEBUG

# ===== 数据库配置覆盖（可选）=====
# TELEHARVEST_DATABASE__URL=sqlite+aiosqlite:///data/teleharvest.db
# TELEHARVEST_DATABASE__ECHO=false

# ===== 存储配置覆盖（可选）=====
# TELEHARVEST_STORAGE__ROOT_DIR=data/downloads
# TELEHARVEST_STORAGE__STRUCTURE=by_channel

# ===== 下载配置覆盖（可选）=====
# TELEHARVEST_DOWNLOADER__MAX_CONCURRENCY=3
# TELEHARVEST_DOWNLOADER__ENABLE_RESUME=true

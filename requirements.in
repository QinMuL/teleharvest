# TeleHarvest 依赖源文件
# 使用 pip-compile 生成 requirements.txt：
#   pip-compile --generate-hashes --output-file=requirements.txt requirements.in
#
# 注意：开发依赖见 pyproject.toml 的 [project.optional-dependencies].dev

# ===== 核心运行时依赖 =====

# Telegram MTProto 客户端
pyrogram>=2.0.106
# TgCrypto 加速 MTProto 加密（需 C 编译器，无此依赖时回退至纯 Python 实现）
tgcrypto>=1.2.5

# 配置管理
pyyaml>=6.0.1
python-dotenv>=1.0.0
pydantic>=2.5.0
pydantic-settings>=2.1.0

# 数据库
sqlalchemy>=2.0.23
aiosqlite>=0.19.0

# 日志
loguru>=0.7.2

# HTTP 客户端（用于元数据抓取等扩展）
httpx>=0.25.2

# 代理支持
pysocks>=1.7.1
# Pyrogram 异步 SOCKS 代理支持（Pyrogram v2 asyncio 模式必需）
python-socks[asyncio]>=2.4.4

# 任务调度
apscheduler>=3.10.4

# 文件类型识别（运行时需 libmagic 系统库）
python-magic>=0.4.27
